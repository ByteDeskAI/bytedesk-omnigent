# Copy to runner.env, fill in, and `set -a; . runner.env; set +a` before running a
# LAPTOP runner (`omnigent run ... --server <url>`). runner.env is gitignored.
#
# This is the same credential set as the in-cluster omnigent-runner-secrets — it
# tells the openai-agents harness how to reach ByteDesk's Codex inference.

# ── Option B (recommended Phase-0 goal): ByteDesk Codex-compatible gateway ──────
# A chat/completions gateway REQUIRES USE_RESPONSES=0 (Responses-wire 404s otherwise).
# Base URL must end in /v1. Pull the URL + key from Infisical (ByteDesk Infrastructure).
HARNESS_OPENAI_AGENTS_GATEWAY_BASE_URL="https://<codex-gateway-host>/v1"
HARNESS_OPENAI_AGENTS_API_KEY="<from-infisical>"
HARNESS_OPENAI_AGENTS_USE_RESPONSES="0"
HARNESS_OPENAI_AGENTS_MODEL="gpt-5.5"

# ── Option A (fastest: prove the fork runs at all) — a direct provider key ──────
# Clear Option B above and uncomment one of these instead:
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."   # (then set the agent's harness to claude-sdk)
